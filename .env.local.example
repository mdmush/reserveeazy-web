# Supabase — copy to .env.local
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: for UI route checks in smoke test
# SMOKE_TEST_APP_URL=http://localhost:3000

# Supabase Auth dashboard setup (manual):
# 1. Authentication → Providers → Email: enabled
# 2. Authentication → URL Configuration:
#    Site URL: http://localhost:3000 (dev) or https://your-domain.com (prod)
#    Redirect URLs:
#      - http://localhost:3000/**
#      - https://your-domain.com/**
# 3. Optional: disable "Confirm email" for faster dev testing
# 4. Optional: enable leaked password protection (recommended for prod)

# Vercel (via GitHub): add these same vars in Project → Settings → Environment Variables
# After deploy, add your Vercel URL to Supabase Auth redirect URLs (see npm run setup:auth)

# Supabase project ref (for CLI): terktsddtkazlyxgdzdz
